<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="smoke" parallel="classes" thread-count="3">
    <listeners>
        <listener class-name="hanh.example.utils.Listeners"/>
    </listeners>
    <test name="smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="hanh.example.tests"/>
        </packages>
    </test>
</suite>